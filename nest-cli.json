{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "webpack",
    "deleteOutDir": false
  },
  "monorepo": true,
  "root": ".",
  "projects": {
    "api-server": {
      "type": "application",
      "root": "apps/api-server",
      "entryFile": "main",
      "sourceRoot": "apps/api-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-server/tsconfig.app.json"
      }
    },
    "activity-worker": {
      "type": "application",
      "root": "apps/activity-worker",
      "entryFile": "main",
      "sourceRoot": "apps/activity-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/activity-worker/tsconfig.app.json"
      }
    },
    "web-server": {
      "type": "application",
      "root": "apps/web-server",
      "entryFile": "main",
      "sourceRoot": "apps/web-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/web-server/tsconfig.app.json"
      }
    },
    "sqs-client": {
      "type": "library",
      "root": "libs/sqs-client",
      "entryFile": "index",
      "sourceRoot": "libs/sqs-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/sqs-client/tsconfig.lib.json"
      }
    },
    "common-utils": {
      "type": "library",
      "root": "libs/common-utils",
      "entryFile": "index",
      "sourceRoot": "libs/common-utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common-utils/tsconfig.lib.json"
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "logger": {
      "type": "library",
      "root": "libs/logger",
      "entryFile": "index",
      "sourceRoot": "libs/logger/src",
      "compilerOptions": {
        "tsConfigPath": "libs/logger/tsconfig.lib.json"
      }
    },
    "prisma-client": {
      "type": "library",
      "root": "libs/prisma-client",
      "entryFile": "index",
      "sourceRoot": "libs/prisma-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/prisma-client/tsconfig.lib.json"
      }
    }
  }
}

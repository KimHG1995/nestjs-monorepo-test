// Prisma 스키마 — 데이터베이스 스키마와 클라이언트를 중앙에서 관리합니다.
// 문서: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

// 스키마가 바뀔 때마다 ERD 를 자동 생성합니다.
// output 을 .md 로 지정하면 mermaid 마크다운으로 출력되어 별도 렌더러(mermaid-cli)가 필요 없습니다.
// 클라이언트만 빠르게 만들고 싶을 땐 `prisma generate --generator client` 를 사용하세요.
generator erd {
  provider = "prisma-erd-generator"
  output   = "../ERD.md"
}

datasource db {
  provider = "postgresql"
}

/// web-server에서 관리하고 사용자 행동 분석의 기준이 되는 상품입니다.
model Product {
  id                String         @id @default(uuid())
  sku               String         @unique
  name              String
  priceInMinorUnits Int            @map("price_in_minor_units")
  currency          String         @default("KRW") @db.Char(3)
  stockQuantity     Int            @default(0) @map("stock_quantity")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  activities        UserActivity[]

  @@index([deletedAt, createdAt])
  @@map("products")
}

/// 사용자 활동 이벤트. activity-worker 가 SQS 메시지를 소비하여 이 테이블에 적재합니다.
model UserActivity {
  id           String    @id @default(uuid())
  /// 활동을 발생시킨 사용자 ID
  userId       String    @map("user_id")
  /// 활동 유형 (login, logout, view_product, add_to_cart ...)
  activityType String    @map("activity_type")
  /// 상품 관련 활동이 가리키는 상품 ID
  productId    String?   @map("product_id")
  product      Product?  @relation(fields: [productId], references: [id], onDelete: Restrict)
  /// 활동에 대한 추가 세부 정보(JSON)
  details      Json?
  /// 클라이언트가 보고한 활동 발생 시각
  occurredAt   DateTime  @map("occurred_at")
  /// 레코드 적재 시각
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([activityType])
  @@index([productId, activityType, occurredAt])
  @@index([userId, productId, occurredAt])
  @@map("user_activities")
}

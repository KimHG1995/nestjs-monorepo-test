# ─────────────────────────────────────────────────────────────
# 공통
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# api-server
# ─────────────────────────────────────────────────────────────
API_SERVER_PORT=3000

# ─────────────────────────────────────────────────────────────
# web-server
# ─────────────────────────────────────────────────────────────
WEB_SERVER_PORT=3002
# HTTPS 로 실행하려면 true 로 바꾸고 아래 인증서 경로를 지정하세요.
HTTPS_ENABLED=false
# HTTPS_KEY_PATH=./certs/key.pem
# HTTPS_CERT_PATH=./certs/cert.pem
# CORS 허용 오리진 (쉼표 구분, * 는 전체 허용)
CORS_ORIGIN=*

# ─────────────────────────────────────────────────────────────
# SQS (api-server, activity-worker) — LocalStack 기본값
# ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
SQS_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/user-activity.fifo
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─────────────────────────────────────────────────────────────
# Database (activity-worker, web-server) — docker-compose postgres 기본값
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public

# activity-worker 의 SQS 폴링 활성화 여부
WORKER_POLLING_ENABLED=true

# RFC 7807 problem type 문서의 베이스 URI (선택)
# PROBLEM_TYPE_BASE_URI=https://example.com/problems

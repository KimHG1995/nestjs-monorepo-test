{
  "name": "nestjs-event-driven-monorepo",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "allowScripts": {
    "@nestjs/core": false,
    "@prisma/engines@7.9.0": true,
    "@swc/core@1.13.4": true,
    "fsevents": false,
    "prisma@7.9.0": true,
    "puppeteer": false
  },
  "scripts": {
    "build": "nest build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:all": "npm run clean && nest build api-server && nest build activity-worker && nest build web-server",
    "format": "prettier --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-server/main",
    "lint": "eslint . --fix",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json",
    "typecheck:tsc": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api-server/test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:erd": "prisma generate --generator erd",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky",
    "postinstall": "prisma generate --generator client"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.592.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/swagger": "^7.4.0",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "dotenv": "17.4.2",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^3.0.0",
    "pg": "8.22.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.3.10",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.13.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^24.0.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^15.2.10",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.0.0",
    "prisma": "7.9.0",
    "prisma-erd-generator": "2.4.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.40.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@app/common-utils(|/.*)$": "<rootDir>/libs/common-utils/src$1",
      "^@app/sqs-client(|/.*)$": "<rootDir>/libs/sqs-client/src$1",
      "^@app/config(|/.*)$": "<rootDir>/libs/config/src$1",
      "^@app/logger(|/.*)$": "<rootDir>/libs/logger/src$1",
      "^@app/prisma-client(|/.*)$": "<rootDir>/libs/prisma-client/src$1"
    },
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ]
  }
}
